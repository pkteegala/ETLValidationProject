[0m18:51:43.935316 [debug] [Thread-1 (]: On model.ETLValidationProject.sales_mart: /* {"app": "dbt", "dbt_version": "1.5.1", "profile_name": "ETLValidationProject", "target_name": "dev", "node_id": "model.ETLValidationProject.sales_mart"} */

  
    
    
    create  table main."sales_mart"
    as
        

with joined as (
    select
        o.order_id,
        p.product_id,
        p.product_description,
        p.category,
        o.qty,
        o.amount,
        o.qty * o.amount as revenue
    from main."stg_orders" o
    join main."stg_products" p
        on o.product_id = p.product_id
)

select
    product_id,
    product_description,
    category,
    sum(qty) as total_qty_sold,
    sum(revenue) as total_revenue
from joined
group by product_id, product_description, category

  
