    create  table main."sales_mart"
    as
        

with joined as (
    select
        o.order_id,
        p.product_id,
        p.product_description,
        p.category,
        p.size,
        p.available,
        p.warehouse,
        o.qty,
        o.unit_price,
        o.amount,
        (o.qty * o.unit_price) as revenue
    from main."stg_orders" o
    join main."stg_products" p
        on o.product_id = p.product_id
)

select
    product_id,
    product_description,
    category,
    size,
    available,
    warehouse,
    sum(qty) as total_qty_sold,
    sum(revenue) as total_revenue
from joined
group by
    product_id, product_description, category, size, available, warehouse

  
